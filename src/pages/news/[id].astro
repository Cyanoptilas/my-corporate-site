---
import Layout from "../../layouts/Layout.astro";
import { getNewsList, getNewsDetail } from "../../lib/microcms";

export async function getStaticPaths() {
    const response = await getNewsList({ fields: ["id"] });
    return response.contents.map((content) => ({
        params: { id: content.id },
    }));
}

const { id } = Astro.params;
const news = await getNewsDetail(id as string);

if (!news) {
    return Astro.redirect("/404");
}
---

<Layout title={`${news.title} - MY CORP News`}>
    <article class="py-24 px-8 max-w-4xl mx-auto">
        <header class="mb-12">
            <a
                href="/news"
                class="text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-brand-orange transition-colors mb-6 block"
                >&larr; Back to News</a
            >
            <h1
                class="text-4xl md:text-6xl font-bold tracking-tighter leading-tight mb-6"
            >
                {news.title}
            </h1>
            <div
                class="flex gap-4 items-center text-gray-500 font-mono text-sm"
            >
                <time datetime={news.publishedAt}>
                    {
                        new Date(news.publishedAt).toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
                {
                    news.category && (
                        <span class="bg-brand-yellow font-bold px-2 py-1 rounded text-xs text-black">
                            {news.category.name}
                        </span>
                    )
                }
            </div>
        </header>

        {
            news.eyecatch && (
                <figure class="mb-16">
                    <img
                        src={news.eyecatch.url}
                        alt={news.title}
                        class="w-full h-auto object-cover aspect-video bg-gray-100"
                    />
                </figure>
            )
        }

        <div
            class="prose prose-xl prose-gray max-w-none"
            set:html={news.content}
        />
    </article>
</Layout>

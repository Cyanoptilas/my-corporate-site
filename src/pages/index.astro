---
import Layout from "../layouts/Layout.astro";
import { getNewsList } from "../lib/microcms";

const { contents: news } = await getNewsList({ limit: 3 });
---

<Layout title="MY CORP - Minimal Corporate Site">
	<!-- Hero Section -->
	<section
		class="h-[80vh] flex flex-col justify-center px-8 max-w-7xl mx-auto"
	>
		<h1
			class="text-6xl md:text-9xl font-bold tracking-tighter leading-none mb-8 animate-hero"
		>
			WE BUILD <br />
			<span class="text-brand-orange">THE FUTURE.</span>
		</h1>
		<p
			class="text-xl md:text-2xl max-w-2xl text-gray-600 animate-hero delay-200"
		>
			We are a digital product studio delivering minimalist and
			high-performance solutions.
		</p>
	</section>

	<!-- Services Section -->
	<section id="services" class="py-24 px-8 border-t border-gray-200">
		<div class="max-w-7xl mx-auto reveal">
			<h2
				class="text-sm font-bold uppercase tracking-widest mb-12 text-gray-500"
			>
				Services
			</h2>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-16">
				<div class="group cursor-pointer reveal fade-left delay-100">
					<div
						class="h-[1px] w-full bg-gray-200 mb-6 group-hover:bg-brand-orange transition-colors duration-500"
					>
					</div>
					<h3 class="text-3xl font-bold mb-4">Digital Strategy</h3>
					<p class="text-gray-600">
						We help brands navigate the digital landscape with
						clear, actionable strategies.
					</p>
				</div>

				<div class="group cursor-pointer reveal fade-left delay-200">
					<div
						class="h-[1px] w-full bg-gray-200 mb-6 group-hover:bg-brand-orange transition-colors duration-500"
					>
					</div>
					<h3 class="text-3xl font-bold mb-4">UI/UX Design</h3>
					<p class="text-gray-600">
						Crafting intuitive and beautiful interfaces that users
						love to interact with.
					</p>
				</div>

				<div class="group cursor-pointer reveal fade-left delay-300">
					<div
						class="h-[1px] w-full bg-gray-200 mb-6 group-hover:bg-brand-orange transition-colors duration-500"
					>
					</div>
					<h3 class="text-3xl font-bold mb-4">Development</h3>
					<p class="text-gray-600">
						Robust and scalable code using the latest modern web
						technologies.
					</p>
				</div>

				<div class="group cursor-pointer reveal fade-left delay-400">
					<div
						class="h-[1px] w-full bg-gray-200 mb-6 group-hover:bg-brand-orange transition-colors duration-500"
					>
					</div>
					<h3 class="text-3xl font-bold mb-4">Branding</h3>
					<p class="text-gray-600">
						Defining your visual identity to stand out in a crowded
						market.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="py-24 px-8 bg-black text-white">
		<div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-16 reveal">
			<div class="md:w-1/3">
				<h2
					class="text-sm font-bold uppercase tracking-widest text-gray-500"
				>
					About Us
				</h2>
			</div>
			<div class="md:w-2/3">
				<p class="text-3xl md:text-5xl font-bold leading-tight mb-8">
					We believe in simplicity. <br />
					By removing the unnecessary, we focus on what truly matters.
				</p>
				<p class="text-lg text-gray-400 max-w-xl">
					Founded in 2024, MY CORP has been at the forefront of
					digital innovation. Our team of experts works tirelessly to
					deliver exceptional results for our clients.
				</p>
			</div>
		</div>
	</section>

	<!-- News Section -->
	<section id="news" class="py-24 px-8 max-w-7xl mx-auto">
		<div class="flex justify-between items-end mb-12 reveal">
			<h2
				class="text-sm font-bold uppercase tracking-widest text-gray-500"
			>
				Latest News
			</h2>
			<a
				href="/news"
				class="text-sm font-bold underline hover:no-underline"
				>View All</a
			>
		</div>

		<div class="divide-y divide-gray-200">
			{
				news.length === 0 ? (
					<p class="py-8 text-gray-500">No news yet.</p>
				) : (
					news.map((item, index) => (
						<article
							class={`py-8 group reveal delay-${(index + 1) * 100}`}
						>
							<a
								href={`/news/${item.id}`}
								class="flex flex-col md:flex-row gap-4 md:items-center justify-between"
							>
								<div class="flex flex-col md:flex-row gap-4 md:items-baseline">
									<time
										class="text-sm text-gray-400 font-mono"
										datetime={item.publishedAt}
									>
										{new Date(
											item.publishedAt,
										).toLocaleDateString("en-US", {
											year: "numeric",
											month: "2-digit",
											day: "2-digit",
										})}
									</time>
									<h3 class="text-xl font-medium group-hover:text-brand-orange transition-colors">
										{item.title}
									</h3>
								</div>
								<span class="text-sm text-gray-400 group-hover:translate-x-2 group-hover:text-brand-yellow transition-all">
									&rarr;
								</span>
							</a>
						</article>
					))
				)
			}
		</div>
	</section>
</Layout>

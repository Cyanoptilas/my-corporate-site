---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact - MY CORP">
    <section class="py-24 px-8 max-w-4xl mx-auto">
        <h1
            class="text-6xl md:text-9xl font-bold tracking-tighter leading-none mb-16"
        >
            CONTACT
        </h1>

        <form
            id="contact-form"
            class="space-y-8"
            method="POST"
            action="/api/submit"
        >
            <div class="space-y-2">
                <label
                    for="name"
                    class="block text-sm font-bold uppercase tracking-widest text-gray-500"
                    >Name</label
                >
                <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full bg-transparent border-b border-gray-300 py-4 text-xl focus:border-brand-orange focus:outline-none transition-colors rounded-none placeholder:text-gray-300"
                    placeholder="Jane Doe"
                />
            </div>

            <div class="space-y-2">
                <label
                    for="email"
                    class="block text-sm font-bold uppercase tracking-widest text-gray-500"
                    >Email Address</label
                >
                <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full bg-transparent border-b border-gray-300 py-4 text-xl focus:border-brand-orange focus:outline-none transition-colors rounded-none placeholder:text-gray-300"
                    placeholder="jane@example.com"
                />
            </div>

            <div class="space-y-2">
                <label
                    for="subject"
                    class="block text-sm font-bold uppercase tracking-widest text-gray-500"
                    >Subject</label
                >
                <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    class="w-full bg-transparent border-b border-gray-300 py-4 text-xl focus:border-brand-orange focus:outline-none transition-colors rounded-none placeholder:text-gray-300"
                    placeholder="Project Inquiry"
                />
            </div>

            <div class="space-y-2">
                <label
                    for="message"
                    class="block text-sm font-bold uppercase tracking-widest text-gray-500"
                    >Message</label
                >
                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    required
                    class="w-full bg-transparent border-b border-gray-300 py-4 text-xl focus:border-brand-orange focus:outline-none transition-colors rounded-none resize-none placeholder:text-gray-300"
                    placeholder="How can we help you?"></textarea>
            </div>

            <div class="pt-8">
                <button
                    type="submit"
                    class="bg-black text-white px-10 py-4 text-sm font-bold uppercase tracking-widest hover:bg-brand-orange transition-colors w-full md:w-auto"
                >
                    Send Message
                </button>
            </div>

            <div
                id="form-status"
                class="hidden text-sm font-bold uppercase tracking-widest"
            >
            </div>
        </form>
    </section>
</Layout>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const status = document.getElementById("form-status");

    if (form && status) {
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const formData = new FormData(form);

            // UI Feedback - sending
            const submitBtn = form.querySelector(
                'button[type="submit"]',
            ) as HTMLButtonElement;
            const originalText = submitBtn.textContent;
            submitBtn.disabled = true;
            submitBtn.textContent = "Sending...";

            try {
                const response = await fetch("/api/submit", {
                    method: "POST",
                    body: formData,
                });

                if (response.ok) {
                    form.reset();
                    status.textContent = "Message sent successfully!";
                    status.className = "text-green-600 block mt-4";
                } else {
                    status.textContent =
                        "Failed to send message. Please try again.";
                    status.className = "text-red-600 block mt-4";
                }
            } catch (error) {
                status.textContent = "An error occurred. Please try again.";
                status.className = "text-red-600 block mt-4";
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        });
    }
</script>

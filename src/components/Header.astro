---
const links = [
    { href: "/", label: "Home" },
    { href: "/#services", label: "Services" },
    { href: "/#about", label: "About" },
    { href: "/news", label: "News" },
    { href: "/contact", label: "Contact" },
];
---

<header
    class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 text-brand-black py-4 px-8 flex justify-between items-center transition-all duration-300"
>
    <a href="/" class="text-xl font-black tracking-tighter"> MY CORP </a>

    <nav>
        <ul class="flex gap-8">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class="text-sm font-bold uppercase tracking-widest hover:text-brand-orange transition-colors"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </nav>
</header>

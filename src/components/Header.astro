---
const links = [
    { href: "/", label: "Home" },
    { href: "/#services", label: "Services" },
    { href: "/#about", label: "About" },
    { href: "/news", label: "News" },
    { href: "/contact", label: "Contact" },
];
---

<header
    class="fixed top-0 left-0 w-full z-50 mix-blend-difference text-white py-6 px-8 flex justify-between items-center bg-transparent pointer-events-none"
>
    <a href="/" class="text-xl font-bold tracking-tighter pointer-events-auto">
        MY CORP
    </a>

    <nav class="pointer-events-auto">
        <ul class="flex gap-8">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class="text-sm uppercase tracking-widest hover:text-brand-orange transition-colors"
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </nav>
</header>

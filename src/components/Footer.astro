---
const year = new Date().getFullYear();
---

<footer class="bg-black text-white py-12 px-8 mt-20 border-t border-gray-800">
    <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-8"
    >
        <div>
            <h2 class="text-3xl font-bold tracking-tighter mb-4">MY CORP</h2>
            <p class="text-gray-400 text-sm">
                Creating the future with minimal design and maximum impact.
            </p>
        </div>

        <div class="flex gap-8 text-sm text-gray-400">
            <a href="/privacy" class="hover:text-brand-yellow transition-colors"
                >Privacy</a
            >
            <a href="/terms" class="hover:text-brand-yellow transition-colors"
                >Terms</a
            >
        </div>
    </div>

    <div
        class="max-w-7xl mx-auto mt-12 pt-8 border-t border-gray-900 text-center text-xs text-gray-600"
    >
        &copy; {year} MY CORP. All rights reserved.
    </div>
</footer>
